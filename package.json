{
    "name": "radlinski.dev",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "lint:format": "prettier --check .",
        "lint:format:fix": "prettier --write .",
        "lint:style": "stylelint '{src,scripts}/**/*.{css,scss,astro}'",
        "lint:style:fix": "stylelint --fix '{src,scripts}/**/*.{css,scss,astro}'",
        "lint:code": "eslint '{src,scripts}/**/*.{js,ts,astro}'",
        "lint:code:fix": "eslint --fix '{src,scripts}/**/*.{js,ts,astro}'",
        "lint": "npm run lint:code && npm run lint:format && npm run lint:style",
        "lint:fix": "npm run lint:code:fix && npm run lint:format:fix && npm run lint:style:fix",
        "dev": "node scripts/generate-resume-pdf.mjs && astro dev",
        "start": "node scripts/generate-resume-pdf.mjs && astro dev",
        "build": "node scripts/generate-resume-pdf.mjs && astro check && astro build",
        "check": "astro check",
        "preview": "astro preview",
        "astro": "astro"
    },
    "dependencies": {
        "@astrojs/check": "0.9.9",
        "@astrojs/markdown-remark": "^7.2.1",
        "@astrojs/mdx": "^7.0.2",
        "@astrojs/rss": "4.0.19",
        "@astrojs/sitemap": "3.7.3",
        "astro": "^7.0.6",
        "rehype-autolink-headings": "^7.1.0",
        "rehype-external-links": "^3.0.0",
        "rehype-slug": "^6.0.0",
        "remark-toc": "^9.0.0",
        "sass": "1.101.0",
        "shiki": "^4.3.1",
        "typescript": "5.9.3"
    },
    "devDependencies": {
        "@typescript-eslint/parser": "8.62.1",
        "eslint": "9.39.4",
        "eslint-plugin-astro": "1.7.0",
        "eslint-plugin-jsx-a11y": "6.10.2",
        "md-to-pdf": "^5.2.5",
        "postcss-html": "1.8.1",
        "prettier": "3.9.4",
        "prettier-plugin-astro": "0.14.1",
        "stylelint": "17.14.0",
        "stylelint-config-html": "1.1.0",
        "stylelint-config-standard": "40.0.0",
        "stylelint-config-standard-scss": "17.0.0"
    }
}
