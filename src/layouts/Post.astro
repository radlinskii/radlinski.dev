---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Divider from "../components/Divider.astro";
import { SITE_TITLE } from "../consts";

type Props = CollectionEntry<"posts">["data"];

const {
    title,
    description,
    pubDate,
    updatedDate,
    heroImage = "",
    tldr,
    heroImageAlt = "",
} = Astro.props;
---

<html lang="en">
    <head>
        <BaseHead
            title={title}
            siteName={SITE_TITLE}
            description={description}
            image={heroImage}
        />
        <style>
            main {
                max-width: 100%;
                margin: 0;
            }

            article {
                padding: 3rem 1rem;

                /* 100vh - header height - footer height - padding - some margin */
                min-height: calc(100vh - 68px - 82px - 6rem - 2px);
            }

            .hero-image {
                width: 100%;
            }

            .hero-image img {
                display: block;
                margin: 0 auto;
                border-radius: 12px;
                box-shadow: var(--box-shadow);
            }

            .prose {
                color: var(--fg-color3);
            }

            @media screen and (width >= 1024px) {
                .prose {
                    margin: auto;
                    width: 980px;
                    max-width: calc(100% - 2rem);
                }

                h1 {
                    font-size: 3.052rem;
                }
            }

            .meta {
                text-align: left;
            }

            .meta-item {
                line-height: 1.1;
                margin-bottom: 0.5rem;
            }

            h1 {
                margin: 2rem 0;
                font-size: 2.5rem;
            }

            .content {
                margin: 0 auto;
                max-width: 720px;
            }

            .divider {
                margin-bottom: 2rem;
            }
        </style>
    </head>

    <body>
        <Header />
        <main>
            <article>
                <div class="hero-image">
                    {
                        heroImage && (
                            <img
                                width={1020}
                                height={510}
                                src={heroImage}
                                alt={heroImageAlt}
                            />
                        )
                    }
                </div>
                <div class="prose">
                    <div class="meta">
                        <h1><span class="unselectable">&gt;</span>{title}</h1>
                    </div>
                    <div class="content">
                        <Divider />
                        <div class="meta-item">
                            <b>published</b> = <FormattedDate date={pubDate} />
                        </div>
                        {
                            updatedDate && (
                                <div class="meta-item">
                                    <b>updated</b> ={" "}
                                    <FormattedDate date={updatedDate} />
                                </div>
                            )
                        }
                        <div class="meta-item">
                            <b>tldr</b> = {tldr}
                        </div>
                        <Divider />
                        <slot />
                    </div>
                </div>
            </article>
        </main>
        <Footer />
    </body>
</html>
