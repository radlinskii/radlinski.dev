---
import ThemeSelect from "./ThemeSelect.astro";
import HeaderLink from "./HeaderLink.astro";
import { SITE_NAME } from "../consts";
---

<header>
    <nav>
        <h2>
            <HeaderLink href="/">{SITE_NAME}/</HeaderLink>
        </h2>
        <div class="nav-panel">
            <HeaderLink href="/posts">/posts</HeaderLink>
            <ThemeSelect />
        </div>
    </nav>
</header>

<style>
    header {
        margin: 0;
        padding: 1rem 2rem;
        display: flex;
        justify-content: center;
        background: var(--bg-color1);
        color: var(--fg-color1);
    }

    nav {
        width: 1280px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    h2 {
        margin: 0;
        font-size: 1.2rem;
    }

    .nav-panel {
        display: flex;
        gap: 2rem;
    }

    @media (width < 1024px) {
        header {
            padding: 0.5rem 1rem;
        }

        .nav-panel {
            gap: 1rem;
        }
    }
</style>
